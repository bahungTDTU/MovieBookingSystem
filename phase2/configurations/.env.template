# =============================================================================
# CineWorld Environment Variables Template - Phase 2 (Traditional Deployment)
# =============================================================================
# Copy this file to /opt/cineworld/config/.env on the server and fill in values.
# NEVER commit the real .env file to version control.
# =============================================================================

# --- Database ---
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=movie_booking_db
MYSQL_USER=cineworld_user
MYSQL_PASSWORD=your_secure_db_password
DATABASE_URL=mysql+pymysql://cineworld_user:your_secure_db_password@localhost:3306/movie_booking_db?charset=utf8mb4

# --- SMTP (OTP / Email Service) ---
# Use a Gmail App Password (not your regular Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_16_digit_app_password

# --- Domain & Protocol ---
SERVER_DOMAIN=tungtungtungtungsahur.site
SERVER_PROTOCOL=https

# --- JWT / Security (optional - set a strong random string) ---
# SECRET_KEY=your_super_secret_key_here

# --- File Upload Directory ---
UPLOAD_DIR=/opt/cineworld/uploads
