# =============================================================================
# CineWorld Environment Variables – Phase 3 Docker Production
# =============================================================================
# Copy this file to .env in the docker-compose/ directory and fill in values.
# NEVER commit the real .env to version control.
# =============================================================================

# --- Docker Hub username (used in image names) ---
DOCKERHUB_USERNAME=your-dockerhub-username

# --- Database ---
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=movie_booking_db
MYSQL_USER=cineworld_user
MYSQL_PASSWORD=your_secure_db_password

# --- Application DB connection string (points to 'db' service) ---
DATABASE_URL=mysql+pymysql://cineworld_user:your_secure_db_password@db:3306/movie_booking_db?charset=utf8mb4

# --- SMTP (OTP / Email service) ---
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_16_digit_app_password

# --- Domain & Protocol ---
SERVER_DOMAIN=tungtungtungtungsahur.site
SERVER_PROTOCOL=https
